# Vercel AI Gateway — powers the /editor "Assistant" chat and shape generation.
# On Vercel this is provided automatically via OIDC. For local dev, create an
# AI Gateway API key (Vercel dashboard → AI Gateway → API Keys) and set it here.
AI_GATEWAY_API_KEY=

# Optional: override the chat model (default: openai/gpt-5.5).
# The "lunar" codename line is openai/gpt-5.6-luna.
# PRINTA_CHAT_MODEL=openai/gpt-5.5

# Early-access gate for the /chat page. Anyone visiting /chat must enter this
# password once (stored in an httpOnly cookie). If unset, a built-in default is
# used so the page still works, but set your own in Vercel for real gating.
CHAT_SIGNUP_PASSWORD=
